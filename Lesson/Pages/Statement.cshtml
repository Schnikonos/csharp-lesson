@page
@model Lesson.Pages.StatementModel

@* =============================================================================
   LESSON 26-B: Razor Pages — server-rendered banking statement

   Key Razor Page concepts shown here:
     @page         — marks this file as a Razor Page (route = /Statement)
     @model        — binds the PageModel; @Model.xxx accesses page properties
     @Html.AntiForgeryToken — injects a hidden CSRF token (Thymeleaf: th:action)
     tag helpers   — <a asp-page="...">, <form method="post">
     partial views — <partial name="_TransactionRow" model="tx" />
     @inject       — constructor-injected services available in the view
     auto-encoding — @Model.CustomerName is HTML-encoded; no manual escaping needed

   Java parallel:
     @page + PageModel  → Thymeleaf template + @Controller/@GetMapping
     @Model.Prop        → ${model.prop} in Thymeleaf / {{ model.prop }} in Jinja2
     <partial>          → th:replace / th:insert fragments
     @inject            → @Autowired in a Thymeleaf VariableExpressionEvaluator
   ============================================================================= *@

@{
    ViewData["Title"] = "Statement";
}

<h1>Bank Statement</h1>
<p>
    Account: <strong>@Model.AccountNumber</strong> —
    Owner: <strong>@Model.CustomerName</strong>
</p>
<p>Period: @Model.PeriodStart to @Model.PeriodEnd</p>

<table>
    <thead>
        <tr><th>Date</th><th>Type</th><th>Amount</th></tr>
    </thead>
    <tbody>
        @foreach (var tx in Model.Transactions)
        {
            <partial name="_TransactionRow" model="tx" />
        }
    </tbody>
</table>

<p>Opening balance: @Model.Currency @Model.OpeningBalance.ToString("0.00")</p>
<p>Closing balance: @Model.Currency @Model.ClosingBalance.ToString("0.00")</p>

@* Anti-forgery token — required for POST forms to protect against CSRF.
   Thymeleaf parallel: <form th:action="@{/statement}" method="post"> auto-adds _csrf *@
<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="accountNumber" value="@Model.AccountNumber" />
    <button type="submit">Download PDF (demo)</button>
</form>
