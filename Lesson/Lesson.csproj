<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Makes the auto-generated Program class visible to the test project -->
    <InternalsVisibleTo>Lesson.Tests</InternalsVisibleTo>
    <!-- User Secrets ID � secrets stored outside the repo, never committed -->
    <UserSecretsId>lesson-02c-banking-app</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.8" />
    <PackageReference Include="Microsoft.FeatureManagement.AspNetCore" Version="4.5.0" />
  </ItemGroup>

</Project>
