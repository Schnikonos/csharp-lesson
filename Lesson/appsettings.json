{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Strongly-typed config section — bound to ExchangeRateOptions via IOptions<T>.
  // Java parallel: application.properties → exchange-rate.base-url=...
  "ExchangeRate": {
    "BaseUrl": "https://open.er-api.com/v6/latest",
    "TimeoutSeconds": 10
  }
}
