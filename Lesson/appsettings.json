{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // ───────────────────────────────────────────────────────────────────────────
  // LESSON 15-B: Serilog configuration
  // ReadFrom.Configuration reads this section automatically when UseSerilog() is called.
  // Sinks:  Console (with [timestamp] format) and a rolling file.
  // Enrich: FromLogContext picks up properties pushed by LogContext.PushProperty (e.g. CorrelationId).
  // Java parallel: logback.xml WriterAppender / RollingFileAppender + MDC enrichment
  // ───────────────────────────────────────────────────────────────────────────
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/banking-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",

  // ───────────────────────────────────────────────────────────────────────────
  // LESSON 03-A: EF Core connection string
  // SQLite file-based DB for local development.
  // In production replace with a real connection string (via env-var or Key Vault).
  // ───────────────────────────────────────────────────────────────────────────
  "ConnectionStrings": {
    "BankDb": "Data Source=bank.db"
  },

  // ───────────────────────────────────────────────────────────────────────────
  // LESSON 02-A: Configuration sections
  //
  // appsettings.json is the primary configuration source in ASP.NET Core.
  // It is loaded automatically by WebApplication.CreateBuilder(args).
  //
  // Java parallel:
  //   application.properties / application.yml  →  appsettings.json
  //   @Value("${bank.name}")                    →  IConfiguration["Bank:Name"]
  //   spring.profiles.active=dev                →  ASPNETCORE_ENVIRONMENT=Development
  //
  // Sections are nested JSON objects. Nested keys are accessed with ":" as
  // a separator: IConfiguration["Bank:Contact:Email"]
  // ───────────────────────────────────────────────────────────────────────────

  "Bank": {
    "Name": "Acme National Bank",
    "SwiftCode": "ACMEGB2L",
    "Country": "UK",
    "MaxTransferLimit": 50000,
    "Contact": {
      "Email": "support@acmebank.com",
      "Phone": "+44 20 7946 0000"
    }
  },

  "FeatureFlags": {
    "EnableFraudDetection": true,
    "EnableInstantPayments": false,
    "MaintenanceMode": false
  },

  // ───────────────────────────────────────────────────────────────────────────
  // LESSON 02-C: Named options — same POCO, different config sub-sections.
  // Accessed via IOptionsMonitor<TransferLimitOptions>.Get("domestic") etc.
  // ───────────────────────────────────────────────────────────────────────────
  "TransferLimits": {
    "Domestic": {
      "DailyLimit": 10000,
      "SingleTransactionLimit": 5000,
      "Currency": "USD"
    },
    "International": {
      "DailyLimit": 3000,
      "SingleTransactionLimit": 1000,
      "Currency": "USD"
    }
  },

  // ───────────────────────────────────────────────────────────────────────────
  // LESSON 13-A: JWT settings
  // SecretKey must be ≥ 32 bytes (256-bit) for HMAC-SHA256.
  // In production, store the key in User Secrets / Azure Key Vault — never source control.
  // ───────────────────────────────────────────────────────────────────────────
  "Jwt": {
    "SecretKey": "lesson-super-secret-key-32-bytes!",
    "Issuer": "LessonBankingApp",
    "Audience": "LessonBankingApp",
    "ExpirySeconds": 3600
  }
}
