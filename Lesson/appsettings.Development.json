{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },

  // ───────────────────────────────────────────────────────────────────────────
  // ENVIRONMENT-SPECIFIC OVERRIDES
  //
  // ASP.NET Core loads configuration sources in this order (later wins):
  //   1. appsettings.json
  //   2. appsettings.{Environment}.json   ← this file (Development)
  //   3. User Secrets (Development only)  ← covered in Lesson 02-C
  //   4. Environment variables
  //   5. Command-line arguments
  //
  // The active environment is set by the ASPNETCORE_ENVIRONMENT variable.
  // In launchSettings.json it is already set to "Development" for local runs.
  //
  // Java parallel:
  //   application-dev.properties (spring.profiles.active=dev)
  //   → appsettings.Development.json (ASPNETCORE_ENVIRONMENT=Development)
  //
  // Only override keys that differ from the base. Keys not listed here
  // keep their appsettings.json value.
  // ───────────────────────────────────────────────────────────────────────────

  "Bank": {
    "Name": "Acme National Bank [DEV]",
    "MaxTransferLimit": 100,
    "Contact": {
      "Email": "dev-team@acmebank.internal"
    }
  },

  "FeatureFlags": {
    "EnableInstantPayments": true,
    "MaintenanceMode": false
  }
}

