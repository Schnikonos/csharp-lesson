{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ───────────────────────────────────────────────────────────────────────────
  // LESSON 02-A: Configuration sections
  //
  // appsettings.json is the primary configuration source in ASP.NET Core.
  // It is loaded automatically by WebApplication.CreateBuilder(args).
  //
  // Java parallel:
  //   application.properties / application.yml  →  appsettings.json
  //   @Value("${bank.name}")                    →  IConfiguration["Bank:Name"]
  //   spring.profiles.active=dev                →  ASPNETCORE_ENVIRONMENT=Development
  //
  // Sections are nested JSON objects. Nested keys are accessed with ":" as
  // a separator: IConfiguration["Bank:Contact:Email"]
  // ───────────────────────────────────────────────────────────────────────────

  "Bank": {
    "Name": "Acme National Bank",
    "SwiftCode": "ACMEGB2L",
    "Country": "UK",
    "MaxTransferLimit": 50000,
    "Contact": {
      "Email": "support@acmebank.com",
      "Phone": "+44 20 7946 0000"
    }
  },

  "FeatureFlags": {
    "EnableFraudDetection": true,
    "EnableInstantPayments": false,
    "MaintenanceMode": false
  }
}
